# services/api — environment variables
# Copy to .env and fill values from Infisical or ask DevOps.

# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=umoja

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# External integrations
STRIPE_SECRET_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# AI service (internal)
AI_CONCIERGE_URL=http://localhost:8000
