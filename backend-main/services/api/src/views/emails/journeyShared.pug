extends baseEmail

block content
  .journey-mail(style='background:#f4f8fb; border-radius:16px; overflow:hidden; border:1px solid #dbe7ef;')
    .journey-mail__hero(style='background:linear-gradient(135deg, #05262f, #0f766e 55%, #14b8a6 105%); color:#ffffff; padding:28px 24px 24px;')
      p(style='margin:0 0 10px; font-size:11px; font-weight:700; letter-spacing:0.22em; text-transform:uppercase; opacity:0.82;') Shared Live View
      h1(style='margin:0; font-size:28px; line-height:1.15; font-weight:700;') Your journey stream is live
      p(style='margin:12px 0 0; font-size:14px; line-height:1.7; max-width:470px; color:rgba(255,255,255,0.9);')
        | Watch real-time segment transitions, location-aware progress, and owner updates inside Umoja Airways.

    .journey-mail__body(style='background:#ffffff; padding:24px;')
      table(role='presentation', width='100%', cellpadding='0', cellspacing='0', style='margin:0 0 18px;')
        tr
          td(style='width:50%; padding-right:8px; vertical-align:top;')
            .info-card(style='background:#f8fafc; border:1px solid #e2e8f0; border-radius:14px; padding:16px;')
              p(style='margin:0 0 6px; font-size:11px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#0f766e;') Shared By
              p(style='margin:0; font-size:18px; font-weight:700; color:#0f172a;') #{sharerName}
              p(style='margin:6px 0 0; font-size:13px; color:#64748b;') #{sharerEmail}
          td(style='width:50%; padding-left:8px; vertical-align:top;')
            .info-card(style='background:#f8fafc; border:1px solid #e2e8f0; border-radius:14px; padding:16px;')
              p(style='margin:0 0 6px; font-size:11px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#0f766e;') Journey ID
              p(style='margin:0; font-size:18px; font-weight:700; color:#0f172a;') #{journeyId}
              p(style='margin:6px 0 0; font-size:13px; color:#64748b;') Read-only live spectator access

      .feature-panel(style='background:linear-gradient(180deg, #f8fbfd, #eef7f8); border:1px solid #d7e9ea; border-radius:14px; padding:18px; margin:0 0 22px;')
        p(style='margin:0 0 10px; font-size:11px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:#0f766e;') What You Can See
        ul(style='margin:0; padding-left:18px; color:#334155; font-size:14px; line-height:1.9;')
          li Live segment transitions as the journey moves forward
          li Timeline and route updates from the journey owner
          li A read-only live view inside your own Umoja account

      .cta-card(style='background:linear-gradient(180deg, #0f172a, #1e293b); border-radius:14px; padding:18px; color:#ffffff;')
        p(style='margin:0 0 12px; font-size:14px; line-height:1.7; color:rgba(255,255,255,0.84);')
          | Open the shared journey now and follow the live experience from your own account.
        table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
          tbody
            tr
              td(align='left')
                table(role='presentation', border='0', cellpadding='0', cellspacing='0')
                  tbody
                    tr
                      td
                        a(href=`${url}`, target='_blank' rel='noopener noreferrer') Open shared journey

      p(style='margin:20px 0 0; color:#64748b; font-size:13px; line-height:1.7;')
        | Sign in first if needed, and we&apos;ll take you straight to the journey.
