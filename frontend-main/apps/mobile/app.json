{
  "expo": {
    "name": "Umojee",
    "slug": "umojee",
    "scheme": "com.nditsolutions.umojee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.nditsolutions.umojee",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Umojee uses your location to show local weather on your home screen."
      }
    },
    "android": {
      "package": "com.nditsolutions.umojee",
      "versionCode": 1,
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f369f654-4773-4d2b-90a2-9f6d5f62027c"
      }
    },
    "owner": "skat-nati",
    "plugins": [
      "expo-video",
      "../../modules/VolumeSOSService/app.plugin.js",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Umojee to access your camera for secure biometric enrollment."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Umojee uses your location to show local weather on your home screen."
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-small-icon.png",
          "color": "#0EA5E9"
        }
      ],
      [
        "react-native-edge-to-edge",
        {
          "android": {
            "parentTheme": "Default",
            "enforceNavigationBarContrast": false
          }
        }
      ]
      
    ]
  }
}