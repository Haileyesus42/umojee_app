  "scripts": {
    "start": "node ./dist/server.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "export:db": "node ./scripts/exportMongoCollections.js",
    "import:db": "node ./scripts/importMongoCollections.js",
    "dev_back": "pwsh -Command \"Start-Process cmd -ArgumentList '/c start-script.bat'\" & nodemon src/server.ts",
    "start:ai": "cd .. && ai/.venv/Scripts/python.exe -m uvicorn ai.server.main:app --host 0.0.0.0 --port 8000",
    "dev:client": "cd ../client && npm start",
    "dev:all": "concurrently \"npm run start:ai\" \"npm run dev\"",
    "dev:full": "concurrently \"npm run start:ai\" \"npm run dev\" \"npm run dev:client\""
  },
