# ============================================
# LLM Configuration
# ============================================
# Choose LLM provider: "groq" or "openai" or "any other supported provider"
LLM_PROVIDER=groq

# Groq Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_TTS_MODEL=canopylabs/orpheus-v1-english
GROQ_TTS_VOICE=tara
GROQ_STT_TIMEOUT_SECONDS=45
GROQ_TTS_TIMEOUT_SECONDS=45

# LLM General Settings
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=0
LLM_MAX_RETRIES=2
LLM_MAX_TOKENS=0


# ============================================
# Database Configuration
# ============================================
SQL_DATABASE_URL=your_sql_database_url_here
MONGODB_URI=your_mongodb_uri_here
MONGODB_DB_NAME=your_mongodb_db_name_here
export REDIS_URL="redis://localhost:6379/0"


# ============================================
# API Keys for External Services
# ============================================
# PHASE 2 CONTEXT MONITORING APIS (UPDATED)

# Amadeus API (Flight Status) - PRIMARY FLIGHT API
# Register at: https://developers.amadeus.com
# Free tier: 2,000 requests/month
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here
AMADEUS_API_URL=https://api.amadeus.com
AI_TRAVEL_PROVIDER=amadeus
DUFFEL_API_URL=https://api.duffel.com
DUFFEL_ACCESS_TOKEN=your_duffel_access_token_here

# Google Maps API (Traffic, Routing, Geocoding, Places) - PRIMARY LOCATION API
# Register at: https://console.cloud.google.com/apis/credentials
# Enable: Distance Matrix API, Directions API, Geocoding API, Places API, Geolocation API
# Pricing: https://developers.google.com/maps/billing-and-pricing/pricing
# Free tier: $200 credit/month (approx 40,000 requests)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google AI API (optional future path for remote embeddings / Gemini features)
GOOGLE_API_KEY=your_google_ai_api_key_here

# OpenWeatherMap API (Weather)
# Register at: https://openweathermap.org/api
# Free tier: 1,000 calls/day
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# AeroDataBox API (Airport data)
AERODATABOX_API_KEY=your_aerodatabox_api_key_here

# OLD Amadeus Config (deprecated - use AMADEUS_API_KEY/SECRET above)
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here


# ============================================
# Server Configuration
# ============================================
PORT=8000
BASE_URL=http://localhost:8000
CLIENT_APP_ORIGIN=http://localhost:3000
LOGIN_URL=http://localhost:3000/login
PGVECTOR_URL=postgresql://postgres:postgres@localhost:5432/nexus_ai


# ============================================
# Application Settings
# ============================================
AI_LOG_PROMPTS=false
VECTOR_SEARCH_ENABLED=true
VECTOR_K=5
VECTOR_NUM_CANDIDATES=50
EMBEDDING_MODEL=intfloat/e5-large-v2
EMBEDDING_MAX_CPU_THREADS=1


# ============================================
# LangSmith Configuration
# ============================================
export LANGSMITH_TRACING=true
export LANGSMITH_ENDPOINT=https://api.smith.langchain.com
export LANGSMITH_API_KEY=your_langsmith_api_key_here
export LANGSMITH_PROJECT=your_langsmith_project_name_here
