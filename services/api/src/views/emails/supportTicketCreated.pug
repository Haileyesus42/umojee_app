extends baseEmail

block content
  .support-ticket(style='background:#f4f7fa; border-radius:10px; overflow:hidden;')
    .support-ticket__header(style='background:linear-gradient(135deg, #2c3e50, rgb(236, 13, 13)); color:#ffffff; padding:24px; text-align:center;')
      h1(style='margin:0; font-size:26px; line-height:1.2;') Support Ticket Created
      p(style='margin:8px 0 0; font-size:14px; opacity:0.92;') Umoja Airways Customer Support
    .support-ticket__body(style='background:#ffffff; padding:24px;')
      p(style='margin:0 0 16px; color:#333333; font-size:15px;') Hi #{firstName},
      p(style='margin:0 0 18px; color:#555555; font-size:15px; line-height:1.6;') Thank you for contacting Umoja Airways support. Your ticket has been created successfully and our team will review it shortly.

      .section(style='margin:0 0 20px; border-bottom:1px dashed #e5e7eb; padding-bottom:20px;')
        .section-title(style='font-size:18px; font-weight:700; color:#2c3e50; margin:0 0 12px; border-bottom:2px solid #4ca1af; display:inline-block; padding-bottom:5px;') Ticket Details
        table.details-table(style='width:100%; border-collapse:collapse; margin-top:6px; font-size:14px; color:#444444;')
          tr
            th(style='text-align:left; padding:10px 12px; background:#f7f7f7; border-bottom:1px solid #eeeeee; width:180px;') Ticket Number
            td(style='padding:10px 12px; border-bottom:1px solid #eeeeee;') #{ticket.ticketNumber}
          tr
            th(style='text-align:left; padding:10px 12px; background:#f7f7f7; border-bottom:1px solid #eeeeee;') Title
            td(style='padding:10px 12px; border-bottom:1px solid #eeeeee;') #{ticket.title}
          tr
            th(style='text-align:left; padding:10px 12px; background:#f7f7f7; border-bottom:1px solid #eeeeee;') Category
            td(style='padding:10px 12px; border-bottom:1px solid #eeeeee;') #{ticket.category}
          tr
            th(style='text-align:left; padding:10px 12px; background:#f7f7f7; border-bottom:1px solid #eeeeee;') Priority
            td(style='padding:10px 12px; border-bottom:1px solid #eeeeee;') #{ticket.priority}
          tr
            th(style='text-align:left; padding:10px 12px; background:#f7f7f7; border-bottom:1px solid #eeeeee;') Status
            td(style='padding:10px 12px; border-bottom:1px solid #eeeeee;') #{ticket.status}
          tr
            th(style='text-align:left; padding:10px 12px; background:#f7f7f7;') Created
            td(style='padding:10px 12px;') #{new Date(ticket.createdAt).toLocaleString()}

      .section(style='margin:0 0 20px; border-bottom:1px dashed #e5e7eb; padding-bottom:20px;')
        .section-title(style='font-size:18px; font-weight:700; color:#2c3e50; margin:0 0 12px; border-bottom:2px solid #4ca1af; display:inline-block; padding-bottom:5px;') Description
        p(style='margin:0; padding:14px 16px; background:#f8fafc; border-left:4px solid #4ca1af; color:#555555; font-size:14px; line-height:1.7;') #{ticket.description}

      .section(style='margin:0; padding-bottom:0;')
        .section-title(style='font-size:18px; font-weight:700; color:#2c3e50; margin:0 0 12px; border-bottom:2px solid #4ca1af; display:inline-block; padding-bottom:5px;') Next Steps
        p(style='margin:0 0 10px; color:#555555; font-size:14px; line-height:1.6;') You can view the full conversation and send additional details from your account support page.
        if ticketUrl
          p(style='margin:0 0 12px; color:#555555; font-size:14px; line-height:1.6;')
            | Click 
            a(href=ticketUrl target='_blank' rel='noopener noreferrer' style='color:#e53935; font-weight:700; text-decoration:none;') here
            |  to access your support ticket.
        p(style='margin:0; color:#555555; font-size:14px; line-height:1.6;') We will reply by email and in your support inbox as soon as an agent responds.

      p(style='margin:22px 0 0; color:#666666; font-size:14px;') Umoja Airways Support Team
