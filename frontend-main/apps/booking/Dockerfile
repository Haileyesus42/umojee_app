FROM node:20-alpine AS builder
WORKDIR /app

ARG REACT_APP_BACKEND_URL
ARG REACT_APP_AI_BACKEND_URL
ARG REACT_APP_FASTAPI_BACKEND_URL
ARG REACT_APP_FRONTEND_URL
ARG REACT_APP_GOOGLE_MAPS_API_KEY
ARG REACT_APP_OPENROUTE_API_KEY

ENV REACT_APP_BACKEND_URL=$REACT_APP_BACKEND_URL
ENV REACT_APP_AI_BACKEND_URL=$REACT_APP_AI_BACKEND_URL
ENV REACT_APP_FASTAPI_BACKEND_URL=$REACT_APP_FASTAPI_BACKEND_URL
ENV REACT_APP_FRONTEND_URL=$REACT_APP_FRONTEND_URL
ENV REACT_APP_GOOGLE_MAPS_API_KEY=$REACT_APP_GOOGLE_MAPS_API_KEY
ENV REACT_APP_OPENROUTE_API_KEY=$REACT_APP_OPENROUTE_API_KEY

COPY package*.json ./
RUN npm ci --legacy-peer-deps
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
