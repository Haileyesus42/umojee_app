extends baseEmail

block content
  .support-ticket(style='background:#f4f7fa; border-radius:10px; overflow:hidden;')
    .support-ticket__header(style='background:linear-gradient(135deg, #2c3e50, rgb(236, 13, 13)); color:#ffffff; padding:24px; text-align:center;')
      h1(style='margin:0; font-size:26px; line-height:1.2;') Google Sign-In Setup
      p(style='margin:8px 0 0; font-size:14px; opacity:0.92;') Your Umoja account is ready
    .support-ticket__body(style='background:#ffffff; padding:24px;')
      p(style='margin:0 0 16px; color:#333333; font-size:15px;') Hi #{firstName},
      p(style='margin:0 0 18px; color:#555555; font-size:15px; line-height:1.6;') Your Umoja account was created with Google sign-in. You can keep signing in with Google, and we have also generated a system password for your account.

      .section(style='margin:0 0 20px; border-bottom:1px dashed #e5e7eb; padding-bottom:20px;')
        .section-title(style='font-size:18px; font-weight:700; color:#2c3e50; margin:0 0 12px; border-bottom:2px solid #4ca1af; display:inline-block; padding-bottom:5px;') System Generated Password
        p(style='margin:0; padding:14px 16px; background:#f8fafc; border-left:4px solid #4ca1af; color:#555555; font-size:14px; line-height:1.7;')
          strong #{generatedPassword}

      .section(style='margin:0 0 20px; border-bottom:1px dashed #e5e7eb; padding-bottom:20px;')
        .section-title(style='font-size:18px; font-weight:700; color:#2c3e50; margin:0 0 12px; border-bottom:2px solid #4ca1af; display:inline-block; padding-bottom:5px;') Important Note
        p(style='margin:0; color:#555555; font-size:14px; line-height:1.7;') You can sign in with Google, but since we may ask for a password in the future, reset this system generated password to one you can remember and keep it for future verification.

      .section(style='margin:0; padding-bottom:0;')
        .section-title(style='font-size:18px; font-weight:700; color:#2c3e50; margin:0 0 12px; border-bottom:2px solid #4ca1af; display:inline-block; padding-bottom:5px;') Reset Your Password
        p(style='margin:0 0 12px; color:#555555; font-size:14px; line-height:1.6;') Use the secure link below to set your own password now.
        table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
          tbody
            tr
              td(align='left')
                table(role='presentation', border='0', cellpadding='0', cellspacing='0')
                  tbody
                    tr
                      td
                        a(href=`${url}`, target='_blank' rel='noopener noreferrer') Reset your password

      p(style='margin:22px 0 0; color:#666666; font-size:14px;') If you did not expect this email, please contact support.
