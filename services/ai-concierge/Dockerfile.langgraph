FROM langchain/langgraph-api:3.11



RUN PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir -c /api/constraints.txt langchain langchain-core langgraph langchain-groq langchain-community fastapi geopy pillow pinecone pinecone-client pymongo python-dotenv requests rich sqlalchemy tavily-python uvicorn sentence-transformers typing-extensions

# -- Adding non-package dependency agent --
ADD ./agent /deps/outer-agent/agent
RUN set -ex && \
    for line in '[project]' \
                'name = "agent"' \
                'version = "0.1"' \
                '[tool.setuptools.package-data]' \
                '"*" = ["**/*"]' \
                '[build-system]' \
                'requires = ["setuptools>=61"]' \
                'build-backend = "setuptools.build_meta"'; do \
        echo "$line" >> /deps/outer-agent/pyproject.toml; \
    done
# -- End of non-package dependency agent --

# -- Adding non-package dependency utils --
ADD ./agent/utils /deps/outer-utils/utils
RUN set -ex && \
    for line in '[project]' \
                'name = "utils"' \
                'version = "0.1"' \
                '[tool.setuptools.package-data]' \
                '"*" = ["**/*"]' \
                '[build-system]' \
                'requires = ["setuptools>=61"]' \
                'build-backend = "setuptools.build_meta"'; do \
        echo "$line" >> /deps/outer-utils/pyproject.toml; \
    done
# -- End of non-package dependency utils --

# -- Adding non-package dependency amadeus --
ADD ./agent/amadeus /deps/outer-amadeus/amadeus
RUN set -ex && \
    for line in '[project]' \
                'name = "amadeus"' \
                'version = "0.1"' \
                '[tool.setuptools.package-data]' \
                '"*" = ["**/*"]' \
                '[build-system]' \
                'requires = ["setuptools>=61"]' \
                'build-backend = "setuptools.build_meta"'; do \
        echo "$line" >> /deps/outer-amadeus/pyproject.toml; \
    done
# -- End of non-package dependency amadeus --

# -- Adding non-package dependency company_information --
ADD ./agent/company_information /deps/outer-company_information/src
RUN set -ex && \
    for line in '[project]' \
                'name = "company_information"' \
                'version = "0.1"' \
                '[tool.setuptools.package-data]' \
                '"*" = ["**/*"]' \
                '[build-system]' \
                'requires = ["setuptools>=61"]' \
                'build-backend = "setuptools.build_meta"'; do \
        echo "$line" >> /deps/outer-company_information/pyproject.toml; \
    done
# -- End of non-package dependency company_information --

# -- Adding non-package dependency server --
ADD ./server /deps/outer-server/server
RUN set -ex && \
    for line in '[project]' \
                'name = "server"' \
                'version = "0.1"' \
                '[tool.setuptools.package-data]' \
                '"*" = ["**/*"]' \
                '[build-system]' \
                'requires = ["setuptools>=61"]' \
                'build-backend = "setuptools.build_meta"'; do \
        echo "$line" >> /deps/outer-server/pyproject.toml; \
    done
# -- End of non-package dependency server --

# -- Installing all local dependencies --
RUN for dep in /deps/*; do             echo "Installing $dep";             if [ -d "$dep" ]; then                 echo "Installing $dep";                 (cd "$dep" && PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir -c /api/constraints.txt -e .);             fi;         done
# -- End of local dependencies install --
ENV LANGSERVE_GRAPHS='{"agent": "/deps/outer-agent/agent/router.py:graph"}'



# -- Ensure user deps didn't inadvertently overwrite langgraph-api
RUN mkdir -p /api/langgraph_api /api/langgraph_runtime /api/langgraph_license && touch /api/langgraph_api/__init__.py /api/langgraph_runtime/__init__.py /api/langgraph_license/__init__.py
RUN PYTHONDONTWRITEBYTECODE=1 uv pip install --system --no-cache-dir --no-deps -e /api
# -- End of ensuring user deps didn't inadvertently overwrite langgraph-api --
# -- Removing build deps from the final image ~<:===~~~ --
RUN pip uninstall -y pip setuptools wheel
RUN rm -rf /usr/local/lib/python*/site-packages/pip* /usr/local/lib/python*/site-packages/setuptools* /usr/local/lib/python*/site-packages/wheel* && find /usr/local/bin -name "pip*" -delete || true
RUN rm -rf /usr/lib/python*/site-packages/pip* /usr/lib/python*/site-packages/setuptools* /usr/lib/python*/site-packages/wheel* && find /usr/bin -name "pip*" -delete || true
RUN uv pip uninstall --system pip setuptools wheel && rm /usr/bin/uv /usr/bin/uvx

